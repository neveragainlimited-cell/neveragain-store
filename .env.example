# Stripe — get these from your Stripe dashboard (stripe.com)
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs — create products in Stripe dashboard, copy the price IDs here
STRIPE_SHIELD_PRICE_ID=price_...
STRIPE_RESCUE_PRICE_ID=price_...
STRIPE_BUNDLE_PRICE_ID=price_...

# Your live site URL
NEXT_PUBLIC_SITE_URL=https://www.neveragainstore.com

# Discount code for email signups (the 10% off code you create in Stripe)
NEXT_PUBLIC_DISCOUNT_CODE=FIRST10

# Resend — free email service for subscriber notifications
# Sign up at resend.com, get API key, add your domain
RESEND_API_KEY=re_...

# Your email — where subscriber notifications go
NOTIFY_EMAIL=info@neveragainstore.com
